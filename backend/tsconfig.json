{
    "compilerOptions": {
        "target": "es2022",
        "module": "es2022",
        "rootDir": "./src",
        "outDir": "dist",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "typeRoots": ["./node_modules/@types", "./src/types"]
    }
}